# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server Configuration
PORT=3000
NODE_ENV=development

# Internal API Key (for admin operations)
VETGO_INTERNAL_API_KEY=your-internal-api-key

# EmailJS OTP provider
EMAIL_SERVICE=service_xxxxxxx
EMAIL_KEY=public_key_xxxxxxx
EMAIL_SECRET=private_key_xxxxxxx
EMAIL_TEMPLATE=template_xxxxxxx
